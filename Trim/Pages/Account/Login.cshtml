@page
@model Trim.Pages.Account.LoginModel
@{
    Layout = null; // Wyłączamy główny układ, to jest samodzielna strona
    ViewData["Title"] = "Logowanie";
}

<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - System CRM</title>

    <!-- Dołączamy Bootstrap 5 z CDN -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />

    <style>
            /* Tło i centrowanie zawartości na pełnym ekranie */
            body {
                background-color: #f4f6f9;
                height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
                margin: 0;
            }

            /* Stylizacja karty logowania */
            .login-card {
                border: none;
                border-radius: 1rem;
                box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.1);
                width: 100%;
                max-width: 400px; /* Ograniczenie szerokości na komputerach */
                padding: 2rem;
            }

            .login-icon {
                font-size: 3.5rem;
                color: #0d6efd;
                margin-bottom: 1rem;
            }
    </style>
</head>
<body>

    <div class="card login-card">
        <div class="card-body text-center p-0">

            <!-- Ikona i nagłówek -->
            <i class="bi bi-person-circle login-icon"></i>
            <h3 class="fw-bold mb-4">Zaloguj się</h3>

            <form method="post" class="text-start">
                <!-- Podsumowanie błędów -->
                <div asp-validation-summary="ModelOnly" class="alert alert-danger p-2 small text-center" style="display: @(ModelState.IsValid ? "none" : "block")"></div>

                <!-- Pole Email (Floating Label) -->
                <div class="form-floating mb-3">
                    <input asp-for="Input.Email" class="form-control" id="floatingInput" placeholder="name@example.com" />
                    <label asp-for="Input.Email">Adres e-mail</label>
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>

                <!-- Pole Hasło (Floating Label) -->
                <div class="form-floating mb-3">
                    <input asp-for="Input.Password" class="form-control" id="floatingPassword" placeholder="Hasło" type="password" />
                    <label asp-for="Input.Password">Hasło</label>
                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                </div>

                <!-- Opcjonalnie: Checkbox "Zapamiętaj mnie" (odkomentuj jeśli masz to w InputModelu) -->
                <!--
                <div class="form-check mb-4">
                    <input asp-for="Input.RememberMe" class="form-check-input" type="checkbox" id="rememberMe">
                    <label asp-for="Input.RememberMe" class="form-check-label text-muted small" for="rememberMe">
                        Zapamiętaj mnie
                    </label>
                </div>
                -->
                <!-- Przycisk logowania -->
                <button type="submit" class="btn btn-primary w-100 py-2 mt-3 fw-bold shadow-sm">
                    <i class="bi bi-box-arrow-in-right me-2"></i>Zaloguj
                </button>
            </form>

        </div>
    </div>

    <!-- Skrypty walidacyjne z CDN (ponieważ Layout = null nie zaciąga ich z _Layout) -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>