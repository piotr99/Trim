@section Scripts {
    <script>
        function LoadOffers(){
            $.ajax({
    url: '/NewUI/home?handler=GetOffers',
    type: 'GET',
    dataType: 'json',
    success: function(data) {
        console.log("Otrzymane dane:", data);
        const container = $('#offers-container');
        let htmlContent = '';
        
        if (data && data.length > 0) {
            // Zmieniono 'data' na 'item' w parametrze pętli
            $.each(data, function(index, item) {

                // Dobranie koloru badge'a 
                // Uwaga: ponieważ C# zwraca sc.Status (Zgłoszenia), mogą tu wpadać np. NEGOTIATION, NEW
                let badgeClass = "bg-secondary";
                if (item.status === "NEGOTIATION" || item.status === "IN_NEGOTIATION") badgeClass = "bg-warning text-dark";
                if (item.status === "NEW") badgeClass = "bg-primary";

                // Płaskie odwołania do item zamiast data.offer
                // Zaktualizowano link do podstrony Case przekazując ID w parametrze
                htmlContent += `
                    <li class="list-group-item p-3">            
                        <a href='/NewUI/Case?id=${item.id}' class="text-decoration-none text-dark">                
                            <div class="d-flex justify-content-between align-items-center">                    
                                <div>                        
                                    <h6 class="mb-0 fw-bold">${item.offerFriendlyName}</h6>                        
                                    <small class="text-muted">${item.customerName}</small>                    
                                </div>                    
                                <span class="badge ${badgeClass} rounded-pill">${item.status}</span>                
                            </div>                
                            <div class="mt-2 small text-secondary">                    
                                <i class="bi bi-truck me-1"></i> Ilość pojazdów: ${item.vehicles}                
                            </div>                
                        </a>            
                    </li>`;
            });
            
            // Wrzucamy zbudowany HTML do kontenera
            container.html(htmlContent);
        } else {
            container.html('<li class="list-group-item p-3 text-muted">Brak powiązanych ofert.</li>');
        }
    },
    error: function(xhr, status, error) {
        console.error("Błąd pobierania ofert:", error);
        $('#offers-container').html('<li class="list-group-item p-3 text-danger">Wystąpił błąd podczas ładowania danych.</li>');
    }
});
}




                function LoadOrders() {
            $.ajax({
                url: '/NewUI/home?handler=GetOrders', // Endpoint zwracający listę zamówień
                type: 'GET',
                dataType: 'json',
                success: function(data) {

                    // 1. Pobieramy element docelowy
                    const container = $('#orders-container');

                    // 2. Czyścimy kontener
                    container.empty();

                    let htmlContent = '';

                    // 3. Sprawdzamy, czy mamy dane
                    if (data && data.length > 0) {

                        // 4. Generujemy HTML dla każdego zamówienia
                        $.each(data, function(index, order) {

                            // Dobranie koloru badge'a na podstawie statusu zamówienia
                            let badgeClass = "bg-primary"; // domyślnie "W realizacji"
                            if (order.status === "NEW") badgeClass = "bg-info text-dark";
                            if (order.status === "COMPLETED") badgeClass = "bg-success";

                            htmlContent += `
                                <li class="list-group-item p-3">
                                    <a href='/NewUI/Case?id=${order.id}' class="text-decoration-none text-dark">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div>
                                                <h6 class="mb-0 fw-bold">${order.orderNumber}</h6>
                                                <small class="text-muted">${order.customerName}</small>
                                            </div>
                                            <span class="badge ${badgeClass} rounded-pill">${order.statusDisplay || order.status}</span>
                                        </div>
                                        <div class="mt-2 small">
                                            <span class="text-success fw-bold">Faktura:</span> ${order.invoiceNumber} (${order.invoiceStatus})<br />
                                            <span class="text-muted">${order.deliveryInfo || 'Brak dodatkowych informacji o dostawie.'}</span>
                                        </div>
                                    </a>
                                </li>
                            `;
                        });
                    } else {
                        htmlContent = '<li class="list-group-item p-3 text-center text-muted">Brak zamówień do wyświetlenia.</li>';
                    }

                    // 5. Wstawiamy gotowy HTML do kontenera
                    container.html(htmlContent);

                },
                error: function(xhr, status, error) {
                    console.error("Błąd AJAX (Zamówienia):", error);
                    const container = $('#orders-container');
                            container.html(`
                            <li class="list-group-item p-4 text-center text-danger">
                                <i class="bi bi-exclamation-triangle-fill fs-4 d-block mb-2"></i>
                                <strong>Wystąpił błąd!</strong> <br/>
                                Nie udało się pobrać listy. Spróbuj ponownie później.
                            </li>
                        `);
                }
            });
        }
