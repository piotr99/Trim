@page "{id:int?}"
@model Trim.Pages.NewUI.CaseModel
@{
    ViewData["Title"] = Model.CurrentCase?.CaseNumber ?? "Brak zgłoszenia";
}
@Html.AntiForgeryToken()
@if (Model.CurrentCase == null)
{
    <div class="alert alert-warning shadow-sm mt-4">
        <i class="bi bi-exclamation-triangle me-2"></i> Nie znaleziono zgłoszenia o podanym numerze lub nie masz do niego dostępu.
    </div>
    <a asp-page="/NewUI/home" class="btn btn-primary mt-2">Wróć do listy</a>
}
else
{
    <!-- NAGŁÓWEK ZGŁOSZENIA -->
    <div class="d-flex justify-content-between align-items-center mb-4 mt-2 pb-3 border-bottom">
        <div>
            <h2 class="mb-0 fw-bold text-dark">
                <i class="bi bi-briefcase me-2 text-primary"></i>@Model.CurrentCase.CaseNumber
            </h2>
            <p class="text-muted fs-5 mb-0">@Model.CurrentCase.Title</p>
        </div>
        <div class="text-end">
            <!-- W ServiceNow status często decyduje o kolorze etykiety -->
            @{
                var badgeClass = Model.CurrentCase.Status.ToString() == "NEW" ? "bg-primary" :
                                 Model.CurrentCase.Status.ToString() == "NEGOTIATION" ? "bg-warning text-dark" :
                                 Model.CurrentCase.Status.ToString() == "CLOSED_WON" ? "bg-success" : "bg-secondary";
            }
            <span class="badge @badgeClass fs-6 px-3 py-2 rounded-pill shadow-sm">
                @Model.CurrentCase.Status
            </span>
            <div class="mt-2 text-muted small">
                Utworzono: @Model.CurrentCase.CreatedAt.ToString("dd.MM.yyyy HH:mm")
            </div>
        </div>
    </div>

    <div class="row g-4">

        <!-- LEWA KOLUMNA: INFORMACJE I ZWIĄZANE REKORDY (7 kolumn) -->
        <div class="col-lg-7">

            <!-- 1. Szczegóły zgłoszenia -->
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-white fw-bold">
                    <i class="bi bi-info-circle me-1"></i> Szczegóły sprawy
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <!-- Zmodyfikowana sekcja: Klient (dodano NIP i Adres) -->
                        <div class="col-md-6">
                            <label class="form-label text-muted small mb-0">Klient</label>
                            <p class="fw-medium mb-1">
                                @(Model.CurrentCase.Customer.CompanyName ?? $"{Model.CurrentCase.Customer.FirstName} {Model.CurrentCase.Customer.LastName}")
                            </p>

                            @if (!string.IsNullOrEmpty(Model.CurrentCase.Customer.TaxId))
                            {
                                <p class="small text-muted mb-0">
                                    <i class="bi bi-building me-1"></i>NIP: @Model.CurrentCase.Customer.TaxId
                                </p>
                            }

                            @if (!string.IsNullOrEmpty(Model.CurrentCase.Customer.Address))
                            {
                                <p class="small text-muted mb-0">
                                    <i class="bi bi-geo-alt me-1"></i>@Model.CurrentCase.Customer.Address
                                </p>
                            }
                        </div>

                        <!-- Zmodyfikowana sekcja: Osoba kontaktowa (dodano Telefon) -->
                        <div class="col-md-6">
                            <label class="form-label text-muted small mb-0">Osoba kontaktowa</label>
                            <p class="mb-1">@Model.CurrentCase.Customer.FirstName @Model.CurrentCase.Customer.LastName</p>
                            <p class="small text-muted mb-0">
                                <i class="bi bi-envelope me-1"></i>@Model.CurrentCase.Customer.Email
                            </p>

                            @if (!string.IsNullOrEmpty(Model.CurrentCase.Customer.PhoneNumber))
                            {
                                <p class="small text-muted mb-0">
                                    <i class="bi bi-telephone me-1"></i>@Model.CurrentCase.Customer.PhoneNumber
                                </p>
                            }
                        </div>
                    </div>

                    <!-- Przypisany Handlowiec (Pozostaje bez zmian) -->
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label text-muted small mb-0">Przypisany Handlowiec</label>

                            <!-- TRYB WYŚWIETLANIA -->
                            <div id="salesman-display-container" class="d-flex align-items-center mt-1">
                                <i class="bi bi-person-badge me-2 text-secondary"></i>
                                <span id="salesman-name" class="fw-medium">
                                    @(Model.CurrentCase.AssignedSalesperson?.FirstName ?? "Brak") @(Model.CurrentCase.AssignedSalesperson?.LastName ?? "")
                                </span>
                                <button id="change-salesman" class="btn btn-sm btn-link text-primary p-0 ms-2" title="Zmień handlowca">
                                    <i class="bi bi-pencil"></i>
                                </button>
                            </div>

                            <!-- TRYB EDYCJI (Domyślnie ukryty) -->
                            <div id="salesman-edit-container" class="d-none mt-1">
                                <div class="input-group input-group-sm">
                                    <select id="salesman-select" class="form-select">
                                        <option value="">Ładowanie...</option>
                                    </select>
                                    <button id="save-salesman" class="btn btn-success" title="Zapisz"><i class="bi bi-check2"></i></button>
                                    <button id="cancel-salesman" class="btn btn-outline-secondary" title="Anuluj"><i class="bi bi-x"></i></button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Opis zgłoszenia (Pozostaje bez zmian) -->
                    <div>
                        <label class="form-label text-muted small mb-0">Opis (Description)</label>
                        <div class="p-3 bg-light rounded text-dark" style="white-space: pre-wrap;">@Model.CurrentCase.Description</div>
                    </div>
                </div>
            </div>

            <!-- 2. Powiązane obiekty (Related Records) -->
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white fw-bold">
                    <i class="bi bi-link-45deg me-1"></i> Powiązane rekordy
                </div>
                <div class="card-body p-0">
                    <ul class="list-group list-group-flush">

                        <!-- Oferta -->
                        <li class="list-group-item d-flex justify-content-between align-items-center p-3">
                            <div>
                                <i class="bi bi-file-earmark-text text-primary me-2 fs-5"></i>
                                <span class="fw-medium">Oferta</span>
                            </div>
                            <div>
                                @if (Model.CurrentCase.Offer != null)
                                {
                                   
                                    <a href="/NewUI/Offers/Details?id=@Model.Id" class="text-decoration-none">
                                        @Model.CurrentCase.Offer.OfferFriendlyName
                                        <i class="bi bi-box-arrow-up-right ms-1 small"></i>
                                    </a>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-outline-primary" id="create-offer">Generuj Ofertę</button>
                                }
                            </div>
                        </li>

                        <!-- Zamówienie -->
                        <li class="list-group-item d-flex justify-content-between align-items-center p-3">
                            <div>
                                <i class="bi bi-cart3 text-success me-2 fs-5"></i>
                                <span class="fw-medium">Zamówienie</span>
                            </div>
                            <div>
                                @if (Model.CurrentCase.Order != null)
                                {
                                    <a href="/NewUI/Orders/Details?id=@Model.Id" class="text-decoration-none text-success">
                                        @Model.CurrentCase.Order.OrderNumber
                                        <i class="bi bi-box-arrow-up-right ms-1 small"></i>
                                    </a>
                                }
                                else
                                {
                                    <span class="text-muted small">Brak powiązanego zamówienia</span>
                                }
                            </div>
                        </li>

                    </ul>
                </div>
            </div>

        </div>

        <!-- PRAWA KOLUMNA: KOMUNIKACJA I ACTIVITY STREAM (5 kolumn) -->
        <div class="col-lg-5">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white fw-bold d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-clock-history me-1"></i> Activity Stream</span>
                </div>

                <div class="card-body d-flex flex-column">

                    <!-- Formularz dodawania nowej wiadomości/notatki -->
                    <div class="mb-4">
                        <!-- Mechanizm a'la ServiceNow: przełącznik "Work notes" / "Additional comments" -->
                        <ul class="nav nav-tabs nav-tabs-sm mb-2" id="activityTab" role="tablist">
                            <li class="nav-item" role="presentation">
                                <button class="nav-link active py-1 px-3 text-dark fw-medium" style="border-top: 3px solid #ffc107;" id="internal-tab" data-bs-toggle="tab" data-bs-target="#internal" type="button" role="tab">Notatka wewn.</button>
                            </li>
                            <li class="nav-item" role="presentation">
                                <button class="nav-link py-1 px-3 text-dark fw-medium" style="border-top: 3px solid #0d6efd;" id="customer-tab" data-bs-toggle="tab" data-bs-target="#customer" type="button" role="tab">Wiadomość do klienta</button>
                            </li>
                        </ul>

                        <div class="tab-content" id="activityTabContent">
                            <div class="tab-pane fade show active" id="internal" role="tabpanel">
                                <textarea class="form-control bg-light border-warning mb-2" rows="3" placeholder="Wpisz notatkę (widoczna tylko dla zespołu)..." style="background-color: #fffdf5 !important;" id="private-textarea"></textarea>
                                <button class="btn btn-warning btn-sm w-100" id="add-private-message">Dodaj notatkę</button>
                            </div>
                            <div class="tab-pane fade" id="customer" role="tabpanel">
                                <textarea class="form-control border-primary mb-2" rows="3" placeholder="Wpisz wiadomość (zostanie wysłana do klienta)..." id="public-textarea"></textarea>
                                <button class="btn btn-primary btn-sm w-100" id="add-public-message">Wyślij wiadomość</button>
                            </div>
                        </div>
                    </div>

                    <hr class="text-muted opacity-25">

                    <!-- Oś czasu wpisów -->
                    <div class="activity-timeline overflow-auto pe-2" style="max-height: 500px;" id="comments-table">

                    </div>
                </div>
            </div>
        </div>

    </div>

}
@section Scripts {
    <script>
        $(document).ready(function() {

            // ==========================================
            // 1. ZMIENNE GLOBALNE WIDOKU
            // ==========================================
            const caseId = @Model.Id;
            const token = $('input[name="__RequestVerificationToken"]').val();
            const container = $('#comments-table');

            // ==========================================
            // 2. FUNKCJE POMOCNICZE (RENDEROWANIE)
            // ==========================================
            function renderComments(comments) {
                // Szybkie wyjście, jeśli brak danych
                if (!comments || comments.length === 0) {
                    container.html(`
                        <div class="text-center text-muted my-5">
                            <i class="bi bi-chat-square-text fs-3 d-block mb-2 text-opacity-50"></i>
                            <span class="small">Brak historii aktywności.</span>
                        </div>
                    `);
                    return;
                }

                let htmlContent = '';

                $.each(comments, function(_, log) {
                    const isInternal = log.direction === 'INTERNAL';
                    const itemClass = isInternal ? 'bg-warning bg-opacity-10 border-warning' : 'bg-light border-secondary border-opacity-25';
                    const iconClass = isInternal ? 'bi-journal-text text-warning' : 'bi-envelope text-primary';
                    const senderName = log.senderName || 'System';
                    const sentDate = new Date(log.sentAt).toLocaleString('pl-PL', {
                        day: '2-digit', month: '2-digit', hour: '2-digit', minute:'2-digit'
                    });

                    htmlContent += `
                        <div class="card mb-3 ${itemClass} border shadow-none">
                            <div class="card-body p-3">
                                <div class="d-flex justify-content-between mb-2">
                                    <span class="fw-bold small">
                                        <i class="bi ${iconClass} me-1"></i> ${senderName}
                                    </span>
                                    <span class="text-muted small">${sentDate}</span>
                                </div>
                                <div class="small text-dark" style="white-space: pre-wrap;">${log.messageContent}</div>
                            </div>
                        </div>`;
                });

                container.html(htmlContent);
            }

            // ==========================================
            // 3. KOMUNIKACJA Z SERWEREM (AJAX)
            // ==========================================
            function fetchComments() {
                $.ajax({
                    url: `/NewUI/Case?handler=GetComments&id=${caseId}`,
                    type: 'GET',
                    dataType: 'json',
                    success: renderComments, // Przekazanie referencji do funkcji
                    error: (xhr, status, error) => console.error("Błąd pobierania komentarzy:", error)
                });
            }

            function sendComment(content, isPrivate, textareaSelector, buttonElement) {
                const originalText = buttonElement.text();
                buttonElement.prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-2"></span>Wysyłanie...');

                $.ajax({
                    url: `/NewUI/Case?handler=SaveComment&id=${caseId}`,
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({ MessageContent: content, IsPrivateMessage: isPrivate }),
                    headers: { "RequestVerificationToken": token },
                    success: function() {
                        $(textareaSelector).val('');
                        fetchComments(); // Odśwież listę po udanym zapisie
                    },
                    error: () => alert("Wystąpił błąd podczas zapisywania."),
                    complete: () => buttonElement.prop('disabled', false).text(originalText)
                });
            }

            // ==========================================
            // 4. INICJALIZACJA I ZDARZENIA (EVENTS)
            // ==========================================

            // Uruchomienie odświeżania osi czasu
            fetchComments();
            setInterval(fetchComments, 5000);

            // Obsługa formularza: Notatka Wewnętrzna
            $('#add-private-message').on('click', function(e) {
                e.preventDefault();
                const content = $('#private-textarea').val().trim();

                if (!content) return alert('Treść nie może być pusta!');
                sendComment(content, true, '#private-textarea', $(this));
            });

            // Obsługa formularza: Wiadomość Publiczna
            $('#add-public-message').on('click', function(e) {
                e.preventDefault();
                const content = $('#public-textarea').val().trim();

                if (!content) return alert('Treść nie może być pusta!');
                sendComment(content, false, '#public-textarea', $(this));
            });


                    // ==========================================
        // OBSŁUGA ZMIANY HANDLOWCA
        // ==========================================

        // 1. Otwarcie trybu edycji i pobranie listy
        $('#change-salesman').on('click', function(e) {
            e.preventDefault();
            const $btn = $(this);
            const originalIcon = $btn.html();

            // Pokaż spinner na przycisku podczas pobierania
            $btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm"></span>');

            $.ajax({
                // UWAGA: Używam nazwy z Twojego kodu C#.
                // Warto rozważyć zmianę nazwy w C# z OnGetLoadCustomersAsync na OnGetLoadSalespeopleAsync dla spójności.
                url: `/NewUI/Case?handler=LoadSalespeople`,
                type: 'GET',
                dataType: 'json',
                success: function(data) {
                    let options = '<option value="">-- Wybierz handlowca --</option>';

                    // Generowanie opcji dla <select>
                    $.each(data, function(index, sp) {
                        options += `<option value="${sp.id}">${sp.firstName} ${sp.lastName}</option>`;
                    });

                    $('#salesman-select').html(options);

                    // Przełączenie widoczności kontenerów
                    $('#salesman-display-container').addClass('d-none');
                    $('#salesman-edit-container').removeClass('d-none').hide().fadeIn(200);
                },
                error: () => alert("Wystąpił błąd podczas wczytywania listy handlowców."),
                complete: () => $btn.prop('disabled', false).html(originalIcon)
            });
        });

        // 2. Anulowanie edycji
        $('#cancel-salesman').on('click', function() {
            $('#salesman-edit-container').addClass('d-none');
            $('#salesman-display-container').removeClass('d-none').hide().fadeIn(200);
        });

        // 3. Zapisanie nowego handlowca
        $('#save-salesman').on('click', function() {
            const selectedId = $('#salesman-select').val();
            const selectedText = $('#salesman-select option:selected').text();

            if (!selectedId) {
                alert('Proszę wybrać handlowca z listy.');
                return;
            }

            const $btn = $(this);
            $btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm"></span>');

            $.ajax({
                url: `/NewUI/Case?handler=ChangeSalesman&id=${caseId}`,
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({ SalespersonId: selectedId }),
                headers: { "RequestVerificationToken": token },
                success: function() {
                    // Aktualizacja tekstu w UI
                    $('#salesman-name').text(selectedText);

                    // Powrót do trybu wyświetlania
                    $('#salesman-edit-container').addClass('d-none');
                    $('#salesman-display-container').removeClass('d-none').hide().fadeIn(200);

                    // Opcjonalnie: dodanie wpisu do Activity Stream o zmianie handlowca
                    fetchComments();
                },
                error: () => alert("Wystąpił błąd podczas przypisywania handlowca."),
                complete: () => $btn.prop('disabled', false).html('<i class="bi bi-check2"></i>')
            });
        });

                $(document).ready(function () {
            // Zakładam, że caseId jest zdefiniowane wyżej w Twoim skrypcie, np.:
            // const caseId = @Model.Id;
            // const token = $('input[name="__RequestVerificationToken"]').val();

            // 1. Obsługa tworzenia oferty
            $('#create-offer').on('click', function() {
                if (confirm('Czy na pewno chcesz wygenerować nową ofertę dla tego zgłoszenia?')) {
                    $.ajax({
                        url: `/NewUI/Case?handler=CreateOffer&id=${caseId}`, // Dodano id zgłoszenia
                        type: 'POST', // Zmiana z GET na POST z powodu modyfikacji danych
                        dataType: 'json',
                        headers: { "RequestVerificationToken": token },
                        success: function(response) {
                            // Po udanym stworzeniu oferty przeładowujemy stronę, aby pokazać powiązany rekord
                            location.reload();
                        },
                        error: function(xhr) {
                            console.error("Błąd tworzenia oferty:", xhr.responseText);
                            alert("Wystąpił błąd podczas tworzenia oferty.");
                        }
                    });
                }
            });
        });
        });
    </script>
}