@page
@model Trim.Pages.NewUI.Orders.DetailsModel
@{
    ViewData["Title"] = "Szczegóły Zamówienia " + Model.CurrentOrder.OrderNumber;
    // Zakładam, że korzystasz ze wspólnego Layoutu dla NewUI
}

<div class="container-fluid py-4">

    <!-- Nagłówek i Powrót -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <a href="/NewUI/Orders/Index" class="text-decoration-none text-muted mb-2 d-inline-block">
                <i class="bi bi-arrow-left me-1"></i> Wróć do listy zamówień
            </a>
            <h2 class="fw-bold mb-0">Zamówienie <span class="text-primary">@Model.CurrentOrder.OrderNumber</span></h2>
        </div>
        <div>
            <!-- Przykładowe akcje administracyjne -->
            <button class="btn btn-outline-secondary me-2"><i class="bi bi-printer"></i> Drukuj PDF</button>
            <button class="btn btn-primary"><i class="bi bi-pencil"></i> Edytuj</button>
        </div>
    </div>

    <div class="row g-4">
        <!-- LEWA KOLUMNA: Pojazdy i Szczegóły -->
        <div class="col-lg-8">

            <!-- Karta: Powiązana Sprawa -->
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center mb-3">
                        <div class="bg-light p-2 rounded-3 me-3 text-primary">
                            <i class="bi bi-briefcase fs-4"></i>
                        </div>
                        <div>
                            <h5 class="fw-bold mb-0">Powiązana Sprawa (Sales Case)</h5>
                            <span class="text-muted small">Źródło tego zamówienia</span>
                        </div>
                    </div>
                    <div class="row bg-light rounded-3 p-3 mx-0">
                        <div class="col-sm-4">
                            <small class="text-muted d-block">Numer sprawy</small>
                            <strong>@Model.CurrentOrder.SalesCase?.CaseNumber</strong>
                        </div>
                        <div class="col-sm-8">
                            <small class="text-muted d-block">Tytuł</small>
                            <strong>@Model.CurrentOrder.SalesCase?.Title</strong>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Karta: Lista Pojazdów -->
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4">
                        <i class="bi bi-truck text-primary me-2"></i>
                        Przypisane pojazdy (@Model.CurrentOrder.Vehicles.Count)
                    </h5>

                    @if (Model.CurrentOrder.Vehicles.Any())
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var vehicle in Model.CurrentOrder.Vehicles)
                            {
                                <div class="list-group-item px-0 py-3 border-bottom">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div class="d-flex align-items-center">
                                            <div class="bg-light p-3 rounded-3 me-3">
                                                <i class="bi bi-car-front text-secondary fs-5"></i>
                                            </div>
                                            <div>
                                                <h6 class="fw-bold mb-1">@vehicle.Name</h6>
                                                <div class="text-muted small">
                                                    <span class="me-3"><i class="bi bi-upc-scan"></i> VIN: <span class="font-monospace text-dark">@vehicle.Vin</span></span>
                                                    <span><i class="bi bi-tag"></i> Status: @vehicle.Status</span>
                                                </div>
                                            </div>
                                        </div>
                                        <button class="btn btn-sm btn-outline-primary">Szczegóły</button>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning border-0 bg-warning bg-opacity-10 text-warning-emphasis mb-0">
                            <i class="bi bi-exclamation-triangle me-2"></i> Brak pojazdów przypisanych do tego zamówienia.
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- PRAWA KOLUMNA: Podsumowanie i Finanse -->
        <div class="col-lg-4">

            <!-- Karta: Status -->
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <h6 class="text-uppercase text-muted fw-bold small mb-3">Status Zamówienia</h6>

                    <!-- Możesz tu dorzucić logikę zmiany kolorów badge w zależności od statusu -->
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <span class="fs-5 fw-bold">Bieżący etap:</span>
                        <span class="badge bg-primary fs-6 px-3 py-2 rounded-pill">@Model.CurrentOrder.Status</span>
                    </div>

                    <hr class="text-muted opacity-25">

                    <form method="post" asp-page-handler="ChangeStatus">
                        <input type="hidden" name="orderId" value="@Model.CurrentOrder.Id" />
                        <label class="form-label small text-muted">Zmień status</label>
                        <div class="input-group">
                            <select name="newStatus" class="form-select" asp-items="Html.GetEnumSelectList<Trim.Models.OrderStatusEnum>()">
                            </select>
                            <button type="submit" class="btn btn-outline-primary">Zapisz</button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Karta: Finanse (Zgodne z polami, o które pytałeś) -->
            <div class="card border-0 shadow-sm rounded-4 bg-primary text-white">
                <div class="card-body p-4">
                    <h6 class="text-uppercase fw-bold small mb-4 opacity-75">
                        <i class="bi bi-wallet2 me-2"></i> Podsumowanie finansowe
                    </h6>

                    <div class="d-flex justify-content-between mb-2">
                        <span class="opacity-75">Cena bazowa</span>
                        <!-- Jeśli przeniosłeś to pole do Order, użyj Model.CurrentOrder.Price -->
                        <span>-- zł</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="opacity-75">Udzielony rabat</span>
                        <span>-- zł</span>
                    </div>

                    <hr class="border-white opacity-25">

                    <div class="d-flex justify-content-between align-items-center mt-3">
                        <span class="fs-6 opacity-75">Kwota końcowa</span>
                        <span class="fs-3 fw-bold">@Model.CurrentOrder.FinalPrice.ToString("C")</span>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>