@page
@model Trim.Pages.NewUI.Offers.DetailsModel
@{
    ViewData["Title"] = "Szczegóły Oferty";
}

<!-- Wskaźnik ładowania widoczny na start -->
<div id="loading-spinner" class="text-center my-5 py-5">
    <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status"></div>
    <h5 class="mt-3 text-muted">Pobieranie detali oferty...</h5>
</div>

<!-- Główny kontener na dane (domyślnie ukryty klasą d-none) -->
<div id="offer-content" class="d-none">
    
    <!-- NAGŁÓWEK -->
    <div class="d-flex justify-content-between align-items-center border-bottom pb-3 mb-4">
        <div>
            <h2 class="fw-bold mb-1 text-dark">
                <i class="bi bi-file-earmark-text text-primary me-2"></i><span id="offer-name">Ładowanie...</span>
            </h2>
            <div class="text-muted small">
                Utworzono: <span id="offer-date" class="fw-medium"></span>
            </div>
        </div>
        <div class="text-end">
            <span id="offer-status" class="badge bg-secondary fs-6 rounded-pill px-3 py-2 shadow-sm mb-2">Ładowanie...</span>
            <h3 class="fw-bold text-success mb-0" id="offer-final-price">0,00 zł</h3>
            <small class="text-muted">Cena końcowa brutto</small>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <!-- DETALE KLIENTA I HANDLOWCA -->
        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white fw-bold"><i class="bi bi-person-lines-fill me-2"></i>Informacje podstawowe</div>
                <div class="card-body">
                    <table class="table table-borderless table-sm mb-0">
                        <tbody>
                            <tr>
                                <td class="text-muted w-25">Klient:</td>
                                <td class="fw-bold text-dark" id="customer-name">-</td>
                            </tr>
                            <tr>
                                <td class="text-muted">Handlowiec:</td>
                                <td id="salesperson-name">-</td>
                            </tr>
                            <tr>
                                <td class="text-muted">Wartość bazowa:</td>
                                <td id="offer-base-price">-</td>
                            </tr>
                            <tr>
                                <td class="text-muted">Rabat / Bonus:</td>
                                <td class="text-danger">
                                    <span id="offer-discount">0,00</span> / <span id="offer-bonus">0,00</span>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- SEKCJA KONFIGURACJI POJAZDÓW -->
    <h4 class="fw-bold mb-3"><i class="bi bi-truck me-2"></i>Skonfigurowane pojazdy (<span id="vehicles-count">0</span>)</h4>
    
    <!-- Tutaj AJAX wrzuci wygenerowane kafelki -->
    <div class="row g-3" id="vehicles-container">
        <!-- Puste miejsce na start -->
    </div>

</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            
            // Pobranie ID oferty z backendu C#
            const offerId = @Model.Id;
            
            // Funkcja pomocnicza do formatowania waluty (PLN)
            const formatPLN = (amount) => {
                if (amount === null || amount === undefined) return "0,00 zł";
                return new Intl.NumberFormat('pl-PL', { style: 'currency', currency: 'PLN' }).format(amount);
            };

            // AJAX pobierający dane od razu po załadowaniu strony
            $.ajax({
                url: `/NewUI/Offers/Details?handler=LoadOffer&id=${offerId}`,
                type: 'GET',
                dataType: 'json',
                success: function (data) {
                    
                    // 1. Wypełnianie nagłówka
                    $('#offer-name').text(data.offerFriendlyName);
                    $('#offer-date').text(data.createdAt || 'Brak daty');
                    $('#offer-final-price').text(formatPLN(data.finalPrice));
                    
                    // Dobranie koloru statusu
                    let statusClass = 'bg-secondary';
                    if (data.status === "DRAFT") statusClass = 'bg-secondary';
                    if (data.status === "SENT" || data.status === "NEGOTIATION") statusClass = 'bg-warning text-dark';
                    if (data.status === "ACCEPTED" || data.status === "WON") statusClass = 'bg-success';
                    
                    $('#offer-status').text(data.status).removeClass('bg-secondary').addClass(statusClass);

                    // 2. Wypełnianie tabeli informacyjnej
                    $('#customer-name').text(data.customer.name);
                    $('#salesperson-name').text(data.salesperson);
                    $('#offer-base-price').text(formatPLN(data.price));
                    $('#offer-discount').text(formatPLN(data.discount));
                    $('#offer-bonus').text(formatPLN(data.bonus));
                    $('#vehicles-count').text(data.vehicles ? data.vehicles.length : 0);

                    // 3. Generowanie kafelków z ciężarówkami
                    const vehiclesContainer = $('#vehicles-container');
                    let vehiclesHtml = '';

                    if (data.vehicles && data.vehicles.length > 0) {
                        $.each(data.vehicles, function (index, v) {
                            
                            // Bezpieczne sprawdzanie czy właściwość istnieje (fallback do "Brak")
                            const engine = v.engine || '<span class="text-muted">Brak</span>';
                            const cab = v.cabSize || '<span class="text-muted">Brak</span>';
                            const gearbox = v.gearbox || '<span class="text-muted">Brak</span>';
                            const drivetrain = v.drivetrain || '<span class="text-muted">Brak</span>';
                            
                            vehiclesHtml += `
                                <div class="col-xl-4 col-lg-6">
                                    <div class="card border-primary border-opacity-25 shadow-sm h-100">
                                        <div class="card-header bg-light d-flex justify-content-between align-items-center">
                                            <span class="fw-bold text-primary"><i class="bi bi-truck-front me-2"></i>Pojazd #${index + 1}</span>
                                            <span class="badge bg-primary rounded-pill">${formatPLN(v.price + (v.additionalPrice || 0))}</span>
                                        </div>
                                        <div class="card-body">
                                            <ul class="list-group list-group-flush small">
                                                <li class="list-group-item px-0 d-flex justify-content-between">
                                                    <span class="text-muted">Silnik:</span> <span class="fw-medium">${engine}</span>
                                                </li>
                                                <li class="list-group-item px-0 d-flex justify-content-between">
                                                    <span class="text-muted">Kabina:</span> <span class="fw-medium">${cab}</span>
                                                </li>
                                                <li class="list-group-item px-0 d-flex justify-content-between">
                                                    <span class="text-muted">Skrzynia:</span> <span class="fw-medium">${gearbox}</span>
                                                </li>
                                                <li class="list-group-item px-0 d-flex justify-content-between">
                                                    <span class="text-muted">Napęd:</span> <span class="fw-medium">${drivetrain}</span>
                                                </li>
                                            </ul>
                                            ${v.additionalEquipment ? `<hr><div class="small text-muted"><strong>Dodatki:</strong><br>${v.additionalEquipment}</div>` : ''}
                                        </div>
                                    </div>
                                </div>
                            `;
                        });
                        vehiclesContainer.html(vehiclesHtml);
                    } else {
                        vehiclesContainer.html('<div class="col-12"><div class="alert alert-light border">Brak skonfigurowanych pojazdów w tej ofercie.</div></div>');
                    }

                    // 4. Ukrycie loadera i pokazanie kontentu z płynnym przejściem
                    $('#loading-spinner').fadeOut(200, function() {
                        $('#offer-content').removeClass('d-none').hide().fadeIn(300);
                    });

                },
                error: function (xhr) {
                    console.error("Błąd pobierania oferty:", xhr.responseText);
                    $('#loading-spinner').html(`
                        <div class="alert alert-danger mx-auto mt-4" style="max-width: 500px;">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                            Wystąpił błąd podczas ładowania szczegółów oferty. Upewnij się, że oferta o ID ${offerId} istnieje.
                        </div>
                    `);
                }
            });
            
        });
    </script>
}