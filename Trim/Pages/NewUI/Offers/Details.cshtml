@page
@model Trim.Pages.NewUI.Offers.DetailsModel
@{
    ViewData["Title"] = "Szczegóły Oferty";
}
@Html.AntiForgeryToken()
<!-- Wskaźnik ładowania widoczny na start -->
<div id="loading-spinner" class="text-center my-5 py-5">
    <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status"></div>
    <h5 class="mt-3 text-muted">Pobieranie detali oferty...</h5>
</div>

<!-- Główny kontener na dane (domyślnie ukryty klasą d-none) -->
<div id="offer-content" class="d-none">
    
    <!-- NAGŁÓWEK -->
    <div class="d-flex justify-content-between align-items-center border-bottom pb-3 mb-4">
        <div>
            <h2 class="fw-bold mb-1 text-dark">
                <i class="bi bi-file-earmark-text text-primary me-2"></i><span id="offer-name">Ładowanie...</span>
            </h2>
            <div class="text-muted small">
                Utworzono: <span id="offer-date" class="fw-medium"></span>
            </div>
        </div>
        <div class="text-end">
            <span id="offer-status" class="badge bg-secondary fs-6 rounded-pill px-3 py-2 shadow-sm mb-2"></span>
            <h3 class="fw-bold text-success mb-0" id="offer-final-price">0,00 zł</h3>
            <small class="text-muted">Cena końcowa brutto</small>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <!-- DETALE KLIENTA I HANDLOWCA -->
        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white fw-bold"><i class="bi bi-person-lines-fill me-2"></i>Informacje podstawowe</div>
                <div class="card-body">
                    <table class="table table-borderless table-sm mb-0">
                        <tbody>
                            <tr>
                                <td class="text-muted w-25">Klient:</td>
                                <td class="fw-bold text-dark" id="customer-name">-</td>
                            </tr>
                            <tr>
                                <td class="text-muted">Handlowiec:</td>
                                <td id="salesperson-name">-</td>
                            </tr>
                            <tr>
                                <td class="text-muted">Wartość bazowa:</td>
                                <td id="offer-base-price">-</td>
                            </tr>
                            <tr>
                                <td class="text-muted">Rabat / Bonus:</td>
                                <td class="text-danger">
                                    <span id="offer-discount">0,00</span> / <span id="offer-bonus">0,00</span>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- SEKCJA KONFIGURACJI POJAZDÓW -->
    <h4 class="fw-bold mb-3"><i class="bi bi-truck me-2"></i>Skonfigurowane pojazdy (<span id="vehicles-count">0</span>)</h4>
    
    <!-- Tutaj AJAX wrzuci wygenerowane kafelki -->
    <div class="row g-3" id="vehicles-container">
        <!-- Puste miejsce na start -->
    </div>

</div>

@section Scripts {
    <script>
                $(document).ready(function () {

            // Pobranie ID oferty z backendu C#
            const offerId = @Model.Id;

            // Funkcja pomocnicza do formatowania waluty (PLN)
            const formatPLN = (amount) => {
                if (amount === null || amount === undefined) return "0,00 zł";
                return new Intl.NumberFormat('pl-PL', { style: 'currency', currency: 'PLN' }).format(amount);
            };

            // AJAX pobierający dane od razu po załadowaniu strony
            $.ajax({
                url: `/NewUI/Offers/Details?handler=LoadOffer&id=${offerId}`,
                type: 'GET',
                dataType: 'json',
                success: function (data) {

                    // 1. Wypełnianie nagłówka
                    $('#offer-name').text(data.offerFriendlyName);
                    $('#offer-date').text(data.createdAt || 'Brak daty');
                    $('#offer-final-price').text(formatPLN(data.finalPrice));

                    // Dobranie koloru statusu
                    let statusClass = 'bg-secondary';
                    if (data.status === "DRAFT") statusClass = 'bg-secondary';
                    if (data.status === "SENT" || data.status === "NEGOTIATION") statusClass = 'bg-warning text-dark';
                    if (data.status === "ACCEPTED" || data.status === "WON") statusClass = 'bg-success';

                    $('#offer-status').text(data.status).removeClass('bg-secondary').addClass(statusClass);

                    // 2. Wypełnianie tabeli informacyjnej
                    $('#customer-name').text(data.customer.name);
                    $('#salesperson-name').text(data.salesperson);
                    $('#offer-base-price').text(formatPLN(data.price));
                    $('#offer-discount').text(formatPLN(data.discount));
                    $('#offer-bonus').text(formatPLN(data.bonus));
                    $('#vehicles-count').text(data.vehicles ? data.vehicles.length : 0);

                    // 3. Generowanie kafelków z ciężarówkami
                    const vehiclesContainer = $('#vehicles-container');
                    let vehiclesHtml = '';

                    if (data.vehicles && data.vehicles.length > 0) {
                        $.each(data.vehicles, function (index, v) {

                            // Bezpieczne sprawdzanie czy właściwość istnieje (fallback do "Brak")
                            const engine = v.engine || '<span class="text-muted">Brak</span>';
                            const cab = v.cabSize || '<span class="text-muted">Brak</span>';
                            const gearbox = v.gearbox || '<span class="text-muted">Brak</span>';
                            const drivetrain = v.drivetrain || '<span class="text-muted">Brak</span>';

                            vehiclesHtml += `
                                <div class="col-xl-4 col-lg-6">
                                    <div class="card border-primary border-opacity-25 shadow-sm h-100">
                                        <div class="card-header bg-light d-flex justify-content-between align-items-center">
                                            <span class="fw-bold text-primary"><i class="bi bi-truck-front me-2"></i>Pojazd #${index + 1}</span>
                                            <div>
                                                <span class="badge bg-primary rounded-pill me-2">${formatPLN(v.price + (v.additionalPrice || 0))}</span>`
                            //usun pojazd kylko kiedy status jest draft
                            if(data.status === "DRAFT" || data.status === "IN_NEGOTIATION")
                                {
                                    vehiclesHtml += `<button type="button" class="btn btn-sm btn-outline-danger delete-vehicle-btn" data-id="${v.id}" title="Usuń pojazd">`
                                }
                            vehiclesHtml +=`
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </div>
                                        </div>
                                        <div class="card-body">
                                            <ul class="list-group list-group-flush small">
                                                <li class="list-group-item px-0 d-flex justify-content-between">
                                                    <span class="text-muted">Silnik:</span> <span class="fw-medium">${engine}</span>
                                                </li>
                                                <li class="list-group-item px-0 d-flex justify-content-between">
                                                    <span class="text-muted">Kabina:</span> <span class="fw-medium">${cab}</span>
                                                </li>
                                                <li class="list-group-item px-0 d-flex justify-content-between">
                                                    <span class="text-muted">Skrzynia:</span> <span class="fw-medium">${gearbox}</span>
                                                </li>
                                                <li class="list-group-item px-0 d-flex justify-content-between">
                                                    <span class="text-muted">Napęd:</span> <span class="fw-medium">${drivetrain}</span>
                                                </li>
                                            </ul>
                                            ${v.additionalEquipment ? `<hr><div class="small text-muted"><strong>Dodatki:</strong><br>${v.additionalEquipment}</div>` : ''}
                                        </div>
                                    </div>
                                </div>
                            `;
                        });
                        

                        // Logika biznesowa: Sprawdzamy status bezpośrednio z obiektu 'data'.
                        // UWAGA: Zmieniłem warunek na "DRAFT", ponieważ zazwyczaj przycisk wysyłania
                        // ma sens tylko wtedy, gdy oferta jest jeszcze szkicem.
                        // Jeśli faktycznie chciałeś wysyłać ponownie na statusie "SENT", po prostu zmień słowo.

                        let actionButtons = ``
                        if (data.status === "ACCEPTED"){
                            
                        }
                        else if (data.status === "DRAFT" || data.status === "IN_NEGOTIATION") {
                            actionButtons += `
                            <div class="col-12 mt-3 d-flex gap-2">
                                <a class="btn btn-outline-primary" href="/NewUI/Vehicles/Configurator?id=@Model.Id">
                                    <i class="bi bi-plus-lg me-1"></i> Skonfiguruj nowy pojazd
                                </a>
                                <button class="btn btn-primary shadow-sm" id="send-offer">
                                    <i class="bi bi-send me-1"></i> Wyślij ofertę klientowi
                                </button>`;
                        }
                        // Przycisk "Wycofaj" pokazujemy, jeśli oferta "żyje" u klienta (jest wysłana lub negocjowana)
                        else {
                            actionButtons += `
                                <button class="btn btn-danger shadow-sm" id="cancel-offer">
                                    <i class="bi bi-x-circle me-1"></i> Wycofaj ofertę
                                </button>`;
                        }

                        actionButtons += `</div>`;

                        // Zamykamy kontener div
                        actionButtons += `</div>`;

                        // Doklejamy przyciski do głównego kodu HTML i wstawiamy na stronę
                        vehiclesHtml += actionButtons;
                        vehiclesContainer.html(vehiclesHtml);

                    } else {
                        // Jeśli nie ma pojazdów, też możemy pokazać ładny przycisk
                        vehiclesContainer.html(`
                            <div class="col-12">
                                <div class="alert alert-light border">Brak skonfigurowanych pojazdów w tej ofercie.</div>
                            </div>
                            <div class="col-12 mt-2">
                                <a class="btn btn-outline-primary" href="/NewUI/Vehicles/Configurator?id=@Model.Id">
                                    <i class="bi bi-plus-lg me-1"></i> Skonfiguruj nowy pojazd
                                </a>
                            </div>
                        `);
                    }

                    // 4. Ukrycie loadera i pokazanie kontentu z płynnym przejściem
                    $('#loading-spinner').fadeOut(200, function() {
                        $('#offer-content').removeClass('d-none').hide().fadeIn(300);
                    });

                },
                error: function (xhr) {
                    console.error("Błąd pobierania oferty:", xhr.responseText);
                    $('#loading-spinner').html(`
                        <div class="alert alert-danger mx-auto mt-4" style="max-width: 500px;">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                            Wystąpił błąd podczas ładowania szczegółów oferty. Upewnij się, że oferta o ID ${offerId} istnieje.
                        </div>
                    `);
                }
            });

            $('#vehicles-container').on('click', '.delete-vehicle-btn', function () {
                const vehicleId = $(this).data('id');

                if (confirm('Czy na pewno chcesz usunąć ten pojazd z oferty? Tej operacji nie można cofnąć.')) {

                    const csrfToken = $('input[name="__RequestVerificationToken"]').val();

                    const btn = $(this);
                    const originalHtml = btn.html();
                    btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>');

                    $.ajax({
                        url: `/NewUI/Offers/Details?handler=DeleteVehicle&vehicleId=${vehicleId}`,
                        type: 'POST', // Używamy POST, ponieważ usuwamy dane z bazy
                        headers: {
                            "RequestVerificationToken": csrfToken
                        },
                        success: function () {
                            location.reload();
                        },
                        error: function (xhr) {
                            console.error("Błąd usuwania pojazdu:", xhr.responseText);
                            alert('Wystąpił błąd podczas usuwania pojazdu. Spróbuj ponownie.');
                            btn.prop('disabled', false).html(originalHtml);
                        }
                    });
                }
            });

        });

            $(document).ready(function () {
            const token = $('input[name="__RequestVerificationToken"]').val();

            // Pobieramy ID oferty z modelu
            const salesCaseId = @Model.Id;

            // ZMIANA: Delegacja zdarzeń!
            // Przypinamy nasłuchiwanie do elementu wyższego rzędu (np. body lub document)
            $(document).on('click', '#send-offer', function(e) {
                e.preventDefault();

                if (confirm('Czy na pewno chcesz wysłać tę ofertę do klienta? Status zgłoszenia ulegnie zmianie.')) {

                    const $btn = $(this);
                    const originalText = $btn.html();

                    // Blokujemy przycisk i pokazujemy ładowanie
                    $btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-2"></span>Wysyłanie...');

                    $.ajax({
                        // UWAGA: Upewnij się, że ten handler jest w odpowiednim pliku.
                        // Zmieniłem zmienną na offerId, bo 'caseId' nie istniało w Twoim kodzie.
                        url: `/NewUI/Offers/Details?handler=SendOffer&id=${salesCaseId}`,
                        type: 'POST',
                        dataType: 'json',
                        headers: { "RequestVerificationToken": token },
                        success: function(response) {
                            location.reload();
                        },
                        error: function(xhr) {
                            console.error("Błąd wysyłania oferty:", xhr.responseText);
                            alert("Wystąpił błąd podczas wysyłania oferty.");

                            // Odblokowanie przycisku
                            $btn.prop('disabled', false).html(originalText);
                        }
                    });
                }
            });

            // Obsługa wycofywania oferty
            $(document).on('click', '#cancel-offer', function(e) {
            e.preventDefault(); 

            if (confirm('Czy na pewno chcesz wycofać tę ofertę? Proces ten zaktualizuje status zgłoszenia i oferty.')) {

                const $btn = $(this);
                const originalText = $btn.html();
                const salesCaseId = @Model.Id;
                console.log(salesCaseId);

                // Blokujemy przycisk
                $btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-2"></span>Wycofywanie...');

                $.ajax({
                    // Pamiętaj o dostosowaniu ścieżki URL do tego, gdzie znajduje się Twój handler
                    url: `/NewUI/Offers/Details?handler=CancelOffer&id=${salesCaseId}`,
                    type: 'POST',
                    dataType: 'json',
                    headers: { "RequestVerificationToken": token },
                    success: function(response) {
                        // Po pomyślnym wycofaniu odświeżamy stronę, by zaktualizować statusy w UI
                        location.reload();
                    },
                    error: function(xhr) {
                        console.error("Błąd wycofywania oferty:", xhr.responseText);
                        alert("Wystąpił błąd podczas wycofywania oferty.");

                        // Odblokowanie przycisku w razie błędu
                        $btn.prop('disabled', false).html(originalText);
                    }
                });
            }
        });
        });
    </script>
}