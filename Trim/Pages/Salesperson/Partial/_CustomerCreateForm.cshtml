@model Trim.Models.ViewModels.CustomerCreateVm

<h2>Dodaj klienta</h2>

<form id="customerCreateForm" method="post" asp-page-handler="CreateCustomer">
    @Html.AntiForgeryToken()

    <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

    <div class="mb-2">
        <label class="form-label" asp-for="Customer.FirstName"></label>
        <input class="form-control" asp-for="Customer.FirstName" />
        <span class="text-danger" asp-validation-for="Customer.FirstName"></span>
    </div>

    <div class="mb-2">
        <label class="form-label" asp-for="Customer.LastName"></label>
        <input class="form-control" asp-for="Customer.LastName" />
        <span class="text-danger" asp-validation-for="Customer.LastName"></span>
    </div>

    <div class="mb-2">
        <label class="form-label" asp-for="Customer.CompanyName"></label>
        <input class="form-control" asp-for="Customer.CompanyName" />
        <span class="text-danger" asp-validation-for="Customer.CompanyName"></span>
    </div>

    <div class="mb-2">
        <label class="form-label" asp-for="Customer.Email"></label>
        <input class="form-control" asp-for="Customer.Email" />
        <span class="text-danger" asp-validation-for="Customer.Email"></span>
    </div>

    <div class="mb-2">
        <label class="form-label" asp-for="Customer.Phone"></label>
        <input class="form-control" asp-for="Customer.Phone" />
        <span class="text-danger" asp-validation-for="Customer.Phone"></span>
    </div>

    <div class="mb-3">
        <label class="form-label" asp-for="Customer.TransportCompanyId">Transport company</label>

        <select class="form-select"
                asp-for="Customer.TransportCompanyId"
                asp-items="Model.TransportCompanies">
            <option value="">-- wybierz firmę --</option>
        </select>
    </div> 
    
    <div class="mb-3">
        <label class="form-label" asp-for="Customer.SalespersonId">Handlowiec</label>

        <select class="form-select" 
                asp-for="Customer.SalespersonId"
                asp-items="Model.Salespeople">
            <option value="">-- wybierz handlowca --</option>
        </select>

        <span class="text-danger" asp-validation-for="Customer.SalespersonId"></span>
    </div>

    <div class="d-flex gap-2">
        <button class="btn btn-primary" type="submit">Zapisz</button>
        <button class="btn btn-outline-secondary js-cancel-customer" type="button">Anuluj</button>
    </div>
</form>
