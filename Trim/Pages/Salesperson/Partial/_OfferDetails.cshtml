@model Trim.Models.ViewModels.OfferDetailsVm
@using System.Globalization

@{
    var offer = Model.Offer;
    string Money(decimal v) => v.ToString("N2", CultureInfo.GetCultureInfo("pl-PL")) + " zł";
}

<div class="card shadow-sm border-0">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-start gap-3">
            <div>
                <h5 class="mb-1">
                    @offer.OfferFriendlyName
                    <span class="badge bg-secondary ms-2">@offer.Status</span>
                </h5>
                <div class="text-muted small">
                    ID oferty: <strong>@offer.Id</strong>
                    <span class="mx-2">•</span>
                    Klient ID: <strong>@offer.CustomerId</strong>
                    <span class="mx-2">•</span>
                    Sprzedawca ID: <strong>@offer.SalespersonId</strong>
                </div>
            </div>

            <div class="text-end">
                <a class="btn btn-primary"
                   asp-page="/Salesperson/NegotiateOffer"
                   asp-route-customerId="@offer.CustomerId"
                   asp-route-offerId="@offer.Id">
                    Negocjuj ofertę
                </a>
            </div>
        </div>

        <hr class="my-3" />

        <div class="row g-3">
            <div class="col-12 col-lg-6">
                <div class="p-3 bg-light rounded">
                    <div class="fw-semibold mb-2">Podsumowanie</div>

                    <div class="d-flex justify-content-between">
                        <span class="text-muted">Status</span>
                        <span>@offer.Status</span>
                    </div>

                    <div class="d-flex justify-content-between">
                        <span class="text-muted">Cena</span>
                        <span class="fw-semibold">@Money(offer.Price)</span>
                    </div>

                    <div class="d-flex justify-content-between">
                        <span class="text-muted">Rabat</span>
                        <span>@Money(offer.Discount)</span>
                    </div>

                    <div class="d-flex justify-content-between">
                        <span class="text-muted">Bonus (marża)</span>
                        <span>@Money(offer.Bonus)</span>
                    </div>

                    <div class="d-flex justify-content-between border-top pt-2 mt-2">
                        <span class="text-muted">Cena ostateczna</span>
                        <span class="fw-bold">@Money(offer.FinalPrice)</span>
                    </div>
                </div>
            </div>

            <div class="col-12 col-lg-6">
                <div class="p-3 bg-light rounded">
                    <div class="fw-semibold mb-2">Akcje</div>

                    <div class="d-flex flex-wrap gap-2">
                        <a class="btn btn-outline-secondary"
                           asp-page="/Salesperson/Offer"
                           asp-route-offerId="@offer.Id">
                            Szczegóły oferty
                        </a>

                        <a class="btn btn-outline-secondary"
                           asp-page="/Salesperson/Customer"
                           asp-route-customerId="@offer.CustomerId">
                            Profil klienta
                        </a>
                    </div>

                    <div class="small text-muted mt-2">
                        Tip: jeśli wprowadzisz edycję, lepiej przejść na VM z polami tylko do widoku.
                    </div>
                </div>
            </div>
        </div>

        @* ===== KONFIGURACJE POJAZDÓW (W PUNKTACH) ===== *@
       @if (Model.OfferVehicleConfigurations is not null && Model.OfferVehicleConfigurations.Count > 0)
{
    <hr class="my-3" />
    <div class="fw-semibold mb-2">Konfiguracje pojazdów w ofercie</div>

    <div class="row g-3">
        @{
            var idx = 1;
        }

        @foreach (var cfg in Model.OfferVehicleConfigurations)
        {
            <div class="col-12 col-lg-6">
                <div class="border rounded p-3 h-100">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <div class="fw-semibold">Pojazd @idx</div>
                        <span class="badge bg-light text-dark">
                            Cena: @cfg.Price
                        </span>
                    </div>

                    <ul class="list-unstyled mb-0">
                        <li class="mb-1"><span class="text-muted">• Kabina:</span> <span class="fw-semibold">@cfg.Size?.Name</span></li>
                        <li class="mb-1"><span class="text-muted">• Silnik:</span> <span class="fw-semibold">@cfg.Engine?.Name</span></li>
                        <li class="mb-1"><span class="text-muted">• Skrzynia:</span> <span class="fw-semibold">@cfg.Gearbox?.Name</span></li>
                        <li class="mb-1"><span class="text-muted">• Wnętrze:</span> <span class="fw-semibold">@cfg.Interior?.Name</span></li>
                        <li class="mb-1"><span class="text-muted">• Napęd:</span> <span class="fw-semibold">@cfg.Drivetrain?.Name</span></li>

                        <li class="mt-2">
                            <span class="text-muted">• Dodatkowe wyposażenie:</span>
                            <span class="fw-semibold">@(!string.IsNullOrWhiteSpace(cfg.AdditionalEquipment) ? cfg.AdditionalEquipment : "brak")</span>
                            @if ((cfg.AdditionalPrice ?? 0) > 0)
                            {
                                <span class="text-muted"> — dopłata:</span>
                                <span class="fw-semibold">@cfg.AdditionalPrice</span>
                            }
                        </li>

                        <li class="mt-2 pt-2 border-top">
                            <span class="text-muted">• Mnożnik bonusu:</span>
                            <span class="fw-semibold">@cfg.BonusMultiplier</span>
                            <span class="mx-2 text-muted">|</span>
                            <span class="text-muted">Bonus:</span>
                            <span class="fw-semibold">@cfg.Bonus</span>
                        </li>
                    </ul>
                </div>
            </div>

            idx++;
        }
    </div>
}
else
{
    <hr class="my-3" />
    <div class="text-muted">Brak pojazdów / konfiguracji do wyświetlenia.</div>
}
    </div>
</div>