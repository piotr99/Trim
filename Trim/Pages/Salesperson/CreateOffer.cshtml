@page
@using Trim.Models
@model Trim.Pages.Salesperson.Partial.CreateOffer

<link rel="stylesheet" href="~/css/Container.css" />

<section class="page">
    <header class="page-header">
        <h2>Utwórz ofertę</h2>
        <p class="muted">Wypełnij dane oferty, pojazdu i konfiguracji. Pola wymagane oznaczone są walidacją.</p>
    </header>

    <form method="post" asp-page-handler="CreateOffer" class="card">
        <input type="hidden" asp-for="customerId" />

        <div asp-validation-summary="All" class="validation-summary"></div>

        <!-- OFERTA -->
        <fieldset class="fieldset">
            <legend>Oferta</legend>

            <div class="grid grid-2">
                <div class="form-group">
                    <label class="form-label" asp-for="NewOffer.OfferFriendlyName">Nazwa/Numer oferty</label>
                    <input class="form-control" asp-for="NewOffer.OfferFriendlyName" />
                    <span class="text-danger" asp-validation-for="NewOffer.OfferFriendlyName"></span>
                </div>

                <div class="form-group">
                    <label class="form-label" asp-for="NewOffer.Status">Status</label>
                    <select class="form-control"
                            asp-for="NewOffer.Status"
                            asp-items="Html.GetEnumSelectList<OfferStatusEnum>()">
                    </select>
                    <span class="text-danger" asp-validation-for="NewOffer.Status"></span>
                </div>
            </div>
        </fieldset>

        <!-- POJAZD -->
        <fieldset class="fieldset">
            <legend>Pojazd</legend>

                <div class="form-group">
                    <label class="form-label" asp-for="NewOption.Price">Cena</label>
                    <input class="form-control" asp-for="NewOption.Price" type="number" step="0.01" />
                    <span class="text-danger" asp-validation-for="NewOption.Price"></span>
                </div>

                <div class="form-group grid-span-2">
                    <label class="form-label" asp-for="NewOption.Description">Opis</label>
                    <input class="form-control" asp-for="NewOption.Description" />
                    <span class="text-danger" asp-validation-for="NewOption.Description"></span>
                </div>
        </fieldset>

        <!-- WERSJA OFERTY -->
        <fieldset class="fieldset">
            <legend>Wersja oferty</legend>

            <div class="grid grid-2">

                <div class="form-group">
                    <label class="form-label" asp-for="NewOfferVersion.Price">Cena</label>
                    <input class="form-control" asp-for="NewOfferVersion.Price" type="number" step="0.01" />
                    <span class="text-danger" asp-validation-for="NewOfferVersion.Price"></span>
                </div>

                <div class="form-group">
                    <label class="form-label" asp-for="NewOfferVersion.Discount">Rabat</label>
                    <input class="form-control" asp-for="NewOfferVersion.Discount" type="number" step="0.01" />
                    <span class="text-danger" asp-validation-for="NewOfferVersion.Discount"></span>
                </div>

                <div class="form-group">
                    <label class="form-label" asp-for="NewOfferVersion.Margin">Marża</label>
                    <input class="form-control" asp-for="NewOfferVersion.Margin" type="number" step="0.01" />
                    <span class="text-danger" asp-validation-for="NewOfferVersion.Margin"></span>
                </div>
            </div>
        </fieldset>

        <!-- PDF -->
        <fieldset class="fieldset">
            <legend>PDF</legend>

            <div class="grid grid-2">
                <div class="form-group grid-span-2">
                    <label class="form-label" asp-for="NewPdfDocument.FilePath">Ścieżka pliku</label>
                    <input class="form-control" asp-for="NewPdfDocument.FilePath" placeholder="np. /files/offers/oferta-123.pdf" />
                    <span class="text-danger" asp-validation-for="NewPdfDocument.FilePath"></span>
                </div>
            </div>
        </fieldset>

        <footer class="form-actions">
            <button type="submit" class="btn btn-primary">Zapisz ofertę</button>
            <a class="btn btn-secondary" asp-page="/Salesperson/CustomerOffers" asp-route-customerId="@Model.customerId">Anuluj</a>
        </footer>
    </form>
</section>
