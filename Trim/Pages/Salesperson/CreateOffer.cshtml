@page
@using Trim.Models
@using Microsoft.AspNetCore.Mvc.Rendering
@model Trim.Pages.Salesperson.Partial.CreateOffer
@{
    var statusItems = Enum.GetValues<OfferStatusEnum>()
        .Where(e => e == OfferStatusEnum.DRAFT || e == OfferStatusEnum.SENT)
        .Select(e => new SelectListItem
        {
            Value = ((int)e).ToString(),
            Text = e.ToString()
        })
        .ToList();

    string BonusText(decimal m) => m != 0 ? $" | Mnożnik bonusu: {m:0.##}" : "";
}

<link rel="stylesheet" href="~/css/Container.css" />

<section class="page">
    <header class="page-header">
        <h2>Utwórz ofertę</h2>
        <p class="muted">Wypełnij dane oferty, pojazdu i konfiguracji. Ceny i marża przeliczają się automatycznie.</p>
    </header>

    <form method="post" asp-page-handler="CreateOffer" class="card">
        <div class="text-danger" asp-validation-summary="All"></div>
        <input type="hidden" asp-for="customerId"/>

        <!-- OFERTA -->
        <fieldset class="fieldset">
            <legend>Oferta</legend>

            <div class="grid grid-2">
                <div class="form-group">
                    <label class="form-label" asp-for="NewOffer.OfferFriendlyName">Nazwa/Numer oferty</label>
                    <input class="form-control" asp-for="NewOffer.OfferFriendlyName"/>
                    <span class="text-danger" asp-validation-for="NewOffer.OfferFriendlyName"></span>
                </div>
            </div>
        </fieldset>

        <!-- POJAZDY / KONFIGURACJE -->
        <fieldset class="fieldset">
            <legend>Pojazdy</legend>

            <div id="vehiclesContainer">
                @for (var i = 0; i < Model.NewVehicleConfigurations.Count; i++)
                {
                    <div class="vehicle-block card mb-3 p-3">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <strong>Pojazd @(i + 1)</strong>
                            <button type="button" class="btn btn-outline-danger btn-sm remove-vehicle"
                                    @(Model.NewVehicleConfigurations.Count == 1 ? "disabled" : "")>
                                Usuń
                            </button>
                        </div>

                        <!-- Cab -->
                        <div class="form-group">
                            <label class="form-label">Rozmiar kabiny</label>
                            <select class="form-control js-size"
                                    asp-for="@Model.NewVehicleConfigurations[@i].SizeId"
                                    asp-items="@(Model.VehicleCabSizes.Select(opt => new SelectListItem
                                               {
                                                   Value = opt.Id.ToString(),
                                                   Text = opt.BonusMultiplier != 0
                                                       ? $"{opt.Name} | Mnożnik bonusu: {opt.BonusMultiplier:0.##}"
                                                       : opt.Name
                                               }))">
                            </select>
                        </div>

                        <!-- Engine -->
                        <div class="form-group">
                            <label class="form-label">Silnik</label>
                            <select class="form-control js-engine"
                                    asp-for="@Model.NewVehicleConfigurations[@i].EngineId"
                                    asp-items="@(Model.VehicleEngines.Select(opt => new SelectListItem
                                               {
                                                   Value = opt.Id.ToString(),
                                                   Text = opt.BonusMultiplier != 0
                                                       ? $"{opt.Name} | Mnożnik bonusu: {opt.BonusMultiplier:0.##}"
                                                       : opt.Name
                                               }))">
                            </select>
                        </div>

                        <!-- Gearbox -->
                        <div class="form-group">
                            <label class="form-label">Skrzynia biegów</label>
                            <select class="form-control js-gearbox"
                                    asp-for="@Model.NewVehicleConfigurations[@i].GearboxId"
                                    asp-items="@(Model.VehicleGearboxes.Select(opt => new SelectListItem
                                               {
                                                   Value = opt.Id.ToString(),
                                                   Text = opt.BonusMultiplier != 0
                                                       ? $"{opt.Name} | Mnożnik bonusu: {opt.BonusMultiplier:0.##}"
                                                       : opt.Name
                                               }))">
                            </select>
                        </div>

                        <!-- Interior -->
                        <div class="form-group">
                            <label class="form-label">Wnętrze</label>
                            <select class="form-control js-interior"
                                    asp-for="@Model.NewVehicleConfigurations[@i].InteriorId"
                                    asp-items="@(Model.VehicleInteriors.Select(opt => new SelectListItem
                                               {
                                                   Value = opt.Id.ToString(),
                                                   Text = opt.BonusMultiplier != 0
                                                       ? $"{opt.Name} | Mnożnik bonusu: {opt.BonusMultiplier:0.##}"
                                                       : opt.Name
                                               }))">
                            </select>
                        </div>

                        <!-- Drivetrain -->
                        <div class="form-group">
                            <label class="form-label">Napęd</label>
                            <select class="form-control js-drivetrain"
                                    asp-for="@Model.NewVehicleConfigurations[@i].DrivetrainId"
                                    asp-items="@(Model.VehicleDrivetrains.Select(opt => new SelectListItem
                                               {
                                                   Value = opt.Id.ToString(),
                                                   Text = opt.BonusMultiplier != 0
                                                       ? $"{opt.Name} | Mnożnik bonusu: {opt.BonusMultiplier:0.##}"
                                                       : opt.Name
                                               }))">
                            </select>
                        </div>

                        <!-- Extra -->
                        <div class="grid grid-2">
                            <div class="form-group">
                                <label class="form-label">Dodatkowe wyposażenie</label>
                                <input class="form-control"
                                       name="NewVehicleConfigurations[@i].AdditionalEquipment"
                                       value="@(Model.NewVehicleConfigurations[i].AdditionalEquipment ?? "")"/>
                            </div>

                            <div class="form-group">
                                <label class="form-label">Dopłata</label>
                                <input class="form-control js-additional-price"
                                       type="number" step="0.01"
                                       name="NewVehicleConfigurations[@i].AdditionalPrice"
                                       value="@(Model.NewVehicleConfigurations[i].AdditionalPrice ?? 0)"/>
                            </div>
                        </div>

                        <!-- CENA POD POJAZDEM -->
                        <div class="vehicle-pricing mt-3 p-2 border rounded">
                            <div class="muted mb-1"><strong>Cena pojazdu</strong></div>

                            <div class="grid grid-3">
                                <div class="form-group">
                                    <label class="form-label">Cena</label>
                                    <input class="form-control js-veh-price" type="number" step="0.01" readonly/>
                                </div>
                            </div>
                        </div>

                        <!-- BONUS POD POJAZDEM -->
                        <div class="vehicle-bonus mt-2 p-2 border rounded">
                            <div class="muted mb-1"><strong>Bonus</strong></div>

                            <div class="grid grid-2">
                                <div class="form-group">
                                    <label class="form-label">Mnożnik bonusu</label>
                                    <input class="form-control js-veh-bonus-mult" type="number" step="0.01" readonly/>
                                </div>

                                <div class="form-group">
                                    <label class="form-label">Bonus</label>
                                    <input class="form-control js-veh-bonus" type="number" step="0.01" readonly/>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <button type="button" class="btn btn-outline-primary" id="addVehicleBtn">
                + Dodaj kolejny pojazd
            </button>
        </fieldset>

        <!-- SUMA ŁĄCZNA -->
        <fieldset class="fieldset">
            <legend>Suma</legend>

            <div class="grid grid-3">
                <div class="form-group">
                    <label class="form-label">Cena łączna</label>
                    <input class="form-control js-total-price" type="number" step="0.01" readonly/>
                </div>

                <div class="form-group">
                    <label class="form-label" asp-for="NewOffer.Discount">Rabat</label>
                    <input class="form-control" asp-for="NewOffer.Discount" type="number" step="0.01"/>
                    <span class="text-danger" asp-validation-for="NewOffer.Discount"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">Cena łączna ostateczna</label>
                    <input class="form-control js-total-final" type="number" step="0.01" readonly/>
                </div>
            </div>

            <div class="grid grid-2">
                <div class="form-group">
                    <label class="form-label">Bonus łączny</label>
                    <input class="form-control js-total-bonus" type="number" step="0.01" readonly/>
                </div>
            </div>
        </fieldset>

        <footer class="form-actions">
            <button type="button" class="btn btn-outline-primary js-save-draft">Zapisz szkic</button>
            <span class="muted js-save-status" style="margin-left: .5rem;"></span>

            <button type="submit" class="btn btn-primary">Zapisz ofertę</button>
            <a class="btn btn-secondary" asp-page="/Salesperson/CustomerOffers" asp-route-customerId="@Model.customerId">Anuluj</a>
        </footer>
    </form>
</section>

@section Scripts {
<script>
    function t() {
        return document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
    }

    const container = document.getElementById("vehiclesContainer");
    const addBtn = document.getElementById("addVehicleBtn");
    const collectionName = "NewVehicleConfigurations";

    function reindex() {
        const blocks = container.querySelectorAll(".vehicle-block");

        blocks.forEach((block, i) => {
            block.querySelectorAll("[name]").forEach(el => {
                el.name = el.name.replace(
                    new RegExp(collectionName + "\\[\\d+\\]", "g"),
                    `${collectionName}[${i}]`
                );
            });

            const header = block.querySelector("strong");
            if (header) header.textContent = `Pojazd ${i + 1}`;
        });

        const removeButtons = container.querySelectorAll(".remove-vehicle");
        removeButtons.forEach(btn => btn.disabled = (blocks.length === 1));
    }

    function clearBlock(block) {
        block.querySelectorAll("select").forEach(sel => sel.selectedIndex = 0);

        block.querySelectorAll("input").forEach(inp => {
            if (inp.classList.contains("js-veh-price") ||
                inp.classList.contains("js-veh-bonus") ||
                inp.classList.contains("js-veh-bonus-mult")) {
                inp.value = "";
                return;
            }
            if (inp.classList.contains("js-additional-price")) {
                inp.value = "0";
                return;
            }
            // nie czyść innych inputów jeśli nie chcesz - tu zostawiamy jak było
            inp.value = "";
        });

        block.querySelectorAll(".text-danger").forEach(span => span.textContent = "");
    }

    function addBlock() {
        const blocks = container.querySelectorAll(".vehicle-block");
        const last = blocks[blocks.length - 1];
        const clone = last.cloneNode(true);

        clearBlock(clone);
        container.appendChild(clone);
        reindex();
        scheduleRecalc();
    }

    function removeBlock(btn) {
        const block = btn.closest(".vehicle-block");
        if (!block) return;
        block.remove();
        reindex();
        scheduleRecalc();
    }

    addBtn.addEventListener("click", addBlock);
    container.addEventListener("click", (e) => {
        const btn = e.target.closest(".remove-vehicle");
        if (btn) removeBlock(btn);
    });

    function collectConfigs() {
        const blocks = container.querySelectorAll(".vehicle-block");

        return Array.from(blocks).map(block => {
            const size = block.querySelector('.js-size')?.value ?? null;
            const engine = block.querySelector('.js-engine')?.value ?? null;
            const gearbox = block.querySelector('.js-gearbox')?.value ?? null;
            const interior = block.querySelector('.js-interior')?.value ?? null;
            const drivetrain = block.querySelector('.js-drivetrain')?.value ?? null;
            const additionalPrice = block.querySelector('.js-additional-price')?.value ?? "0";

            return {
                size: size ? Number(size) : null,
                engine: engine ? Number(engine) : null,
                gearbox: gearbox ? Number(gearbox) : null,
                interior: interior ? Number(interior) : null,
                drivetrain: drivetrain ? Number(drivetrain) : null,
                additionalPrice: Number(additionalPrice || 0)
            };
        });
    }

    function fmt(n) {
        // żeby nie wyświetlać "12.333333333"
        return Number(n ?? 0).toFixed(2);
    }

    function setVehiclePricing(index, p) {
        const blocks = container.querySelectorAll(".vehicle-block");
        const block = blocks[index];
        if (!block) return;

        const priceEl = block.querySelector(".js-veh-price");
        const bonusMultEl = block.querySelector(".js-veh-bonus-mult");
        const bonusEl = block.querySelector(".js-veh-bonus");

        if (priceEl) priceEl.value = fmt(p?.price);
        if (bonusMultEl) bonusMultEl.value = fmt(p?.bonusMultiplier);
        if (bonusEl) bonusEl.value = fmt(p?.bonus);
    }

    function setTotals(tot) {
        document.querySelector(".js-total-price").value = fmt(tot?.price);
        document.querySelector(".js-total-final").value = fmt(tot?.finalPrice);

        const tb = document.querySelector(".js-total-bonus");
        if (tb) tb.value = fmt(tot?.bonus);
    }

    // ===== ENTER: nie wysyła formularza (żeby nie robić przypadkowego submitu) =====
    document.addEventListener("keydown", (e) => {
        if (e.key !== "Enter") return;

        const el = e.target;
        if (!el) return;

        const tag = (el.tagName || "").toLowerCase();
        if (tag === "textarea") return;   // w textarea enter działa normalnie
        if (tag === "button") return;     // enter na buttonie ok

        // blokuj automatyczne submitowanie formularza enterem
        e.preventDefault();
    }, true);

    // ===== KALKULACJA (AUTO) =====
    const discountEl = document.querySelector('#NewOffer_Discount');

    let recalcTimer = null;
    function scheduleRecalc() {
        if (recalcTimer) clearTimeout(recalcTimer);
        recalcTimer = setTimeout(recalcAjax, 250);
    }

    async function recalcAjax() {
        const discount = discountEl?.value ?? "0";
        const configs = collectConfigs();
        const payload = JSON.stringify(configs);

        const body = new URLSearchParams();
        body.append("__RequestVerificationToken", t());
        body.append("payload", payload);
        body.append("discount", discount);

        const r = await fetch('?handler=CalculateMargin', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: body.toString(),
            credentials: 'same-origin'
        });

        if (!r.ok) {
            console.error("CalculateMargin failed:", await r.text());
            return;
        }

        const data = await r.json();

        if (Array.isArray(data.vehicles)) {
            data.vehicles.forEach((p, i) => setVehiclePricing(i, p));
        }
        setTotals(data.total);
    }

    // zmiana selectów/dopłaty => przelicz
    container.addEventListener("change", (e) => {
        if (e.target.matches("select") || e.target.classList.contains("js-additional-price")) {
            scheduleRecalc();
        }
    });

    // zmiana rabatu => przelicz
    if (discountEl) discountEl.addEventListener("input", scheduleRecalc);

    // (opcjonalnie) przycisk przelicz jeśli go masz gdzieś
    const btn = document.querySelector('.js-update-margin');
    if (btn) btn.addEventListener("click", (e) => {
        e.preventDefault();
        scheduleRecalc();
    });

    const form = document.querySelector('form');
    const saveBtn = document.querySelector(".js-save-draft");
    const saveStatus = document.querySelector(".js-save-status");

    function setSaveStatus(text) {
        if (saveStatus) saveStatus.textContent = text ?? "";
    }

    async function saveDraftAjax() {
        try {
            setSaveStatus("Zapisywanie...");

            const fd = new FormData(form); // bierze całe NewOffer + NewVehicleConfigurations[*].*.Id + discount itd.
            for (const [k, v] of fd.entries()) {
                console.log(k, v);
            }

            const r = await fetch("?handler=SaveDraft", {
                method: "POST",
                body: fd,
                credentials: "same-origin"
            });

            if (!r.ok) {
                console.error("SaveDraft failed:", await r.text());
                setSaveStatus("Błąd zapisu");
                return;
            }

            const data = await r.json();
            // backend może zwrócić np. { ok:true, savedAt:"2026-03-03 12:34", offerId:123 }
            setSaveStatus(data?.savedAt ? `Zapisano: ${data.savedAt}` : "Zapisano");
        } catch (e) {
            console.error(e);
            setSaveStatus("Błąd zapisu");
        }
    }

    if (saveBtn) {
        saveBtn.addEventListener("click", (e) => {
            e.preventDefault();
            saveDraftAjax();
        });
    }
    
    // start
    reindex();
    scheduleRecalc();
</script>
}