@page
@model Trim.Pages.Salesperson.ManageCustomers
@{
    ViewData["Title"] = "Manage customers";
}
<link rel="stylesheet" href="~/css/Container.css" />

<div class="container1">
    <div class="left-panel">

        <button type="button" class="btn btn-success w-100 mb-3 js-add-customer">
            Dodaj klienta
        </button>
        
        <form method="get" class="mb-3">
            <div class="form-group mb-2">
                <label asp-for="Filter">Filter</label>
                <input asp-for="Filter" class="form-control" />
            </div>

            <button type="submit" class="btn btn-primary">Filtruj</button>
            <a class="btn btn-outline-secondary" asp-page="/Salesperson/ManageCustomers">Wyczyść</a>
        </form>

        @foreach (var customer in Model.Customers)
        {
            <button type="button"
                    class="item-button d-block text-decoration-none js-customer"
                    data-id="@customer.Id">
                <div class="item-button-main">
                    <span class="item-name">@customer.FirstName @customer.LastName</span>
                    <p>@customer.CompanyName</p>
                </div>
            </button>
        }

        <div class="page-buttons mt-3 d-flex align-items-center gap-2">
            <a class="btn btn-outline-primary @(Model.HasPrev ? "" : "disabled")"
               asp-page="/Salesperson/ManageCustomers"
               asp-route-Filter="@Model.Filter"
               asp-route-CurrentPage="@(Model.CurrentPage - 1)">
                -1
            </a>

            <span>@Model.CurrentPage / @Model.TotalPages</span>

            <a class="btn btn-outline-primary @(Model.HasNext ? "" : "disabled")"
               asp-page="/Salesperson/ManageCustomers"
               asp-route-Filter="@Model.Filter"
               asp-route-CurrentPage="@(Model.CurrentPage + 1)">
                +1
            </a>
        </div>
        
        @Html.AntiForgeryToken()
        
        </div>

    <div class="right-panel" id="rightPanel">
    </div>
    </div>

@section Scripts {
    <script>
const t = () => document.querySelector('input[name="__RequestVerificationToken"]').value;
const rp = document.getElementById('rightPanel');

document.querySelectorAll('.js-customer').forEach(b => b.onclick = async () => {
  const r = await fetch('?handler=CustomerDetailsPartial', {
    method: 'POST',
    headers: {'Content-Type':'application/x-www-form-urlencoded'},
    body: `customerId=${encodeURIComponent(b.dataset.id)}&__RequestVerificationToken=${encodeURIComponent(t())}`
  });
  rp.innerHTML = await r.text();
});

document.querySelector('.js-add-customer').onclick = async () => {
  const r = await fetch('?handler=CustomerCreateFormPartial', {
    method: 'POST',
    headers: {'Content-Type':'application/x-www-form-urlencoded'},
    body: `__RequestVerificationToken=${encodeURIComponent(t())}`
  });
  rp.innerHTML = await r.text();
};
</script>
}

