@page
@using Microsoft.IdentityModel.Tokens
@model Trim.Pages.Salesperson.CustomerOffers

@{
}
<link rel="stylesheet" href="~/css/Container.css" />

<div class="container1">
    <div class="left-panel">

        <button type="button" class="btn btn-success w-100 mb-3 js-add----------------------">
            Dodaj Ofertę
        </button>
        
        <form method="get" class="mb-3">
            <input type="hidden" name="customerId" value="@Model.customerId" />

            <div class="form-group mb-2">
                <label asp-for="Filter">Filter</label>
                <input asp-for="Filter" class="form-control" />
            </div>

            <button type="submit" class="btn btn-primary">Filtruj</button>

            <a class="btn btn-outline-secondary"
               asp-page="/Salesperson/CustomerOffers"
               asp-route-customerId="@Model.customerId">
                Wyczyść
            </a>
        </form>

        Liczba ofert: @Model.Offers.Count()
        klinet: @Model.customerId
        @if (Model.Offers.IsNullOrEmpty())
        {
            <h3>Brak ofert</h3>
        }
        else
        {
            @foreach (var offer in Model.Offers)
            {
                <button type="button"
                        class="item-button d-block text-decoration-none js-offer"
                        data-id="@offer.Id">
                    <div class="item-button-main">
                        <span class="item-name">@offer.Id @offer.Status</span>
                        <p>@offer.Vehicle.Name</p>
                    </div>
                </button>
            }
        }
        
        
        
        @Html.AntiForgeryToken()
        
    </div>

    <div class="right-panel" id="rightPanel">
    </div>
</div>

@section Scripts {
    <script>
document.querySelectorAll('.js-offer').forEach(b => b.onclick = async () => {
  const t = document.querySelector('input[name="__RequestVerificationToken"]').value;
  const id = b.dataset.id;
  const r = await fetch('?handler=OfferDetailsPartial', {
    method: 'POST',
    headers: {'Content-Type':'application/x-www-form-urlencoded'},
    body: `offerId=${encodeURIComponent(id)}&__RequestVerificationToken=${encodeURIComponent(t)}`
  });
  document.getElementById('rightPanel').innerHTML = await r.text();
});
</script>
}