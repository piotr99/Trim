document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('offersFilterForm');
    const clearBtn = document.getElementById('ClearFilterBtn');
    const filterEl = document.getElementById('Filter');

    if (!form || !filterEl) return;

    function getCustomerId() {
        return Number(form.querySelector('input[name="customerId"]')?.value ?? 0);
    }

    // Filtruj (submit formularza)
    form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const customerId = getCustomerId();
        if (!customerId) return;

        await refreshOffersList(customerId, filterEl.value);
    });

    // Wyczyść
    if (clearBtn) {
        clearBtn.addEventListener('click', async () => {
            filterEl.value = "";
            const customerId = getCustomerId();
            if (!customerId) return;

            await refreshOffersList(customerId, "");
        });
    }
});

document.addEventListener('click', async (e) => {
    const save = e.target.closest('.js-save-offer');
    if (!save) return;

    e.preventDefault();
    await postUpdateOfferPartial();
    const customerId = Number(getHiddenValue('customerId') || 0)
    const filterEl = document.getElementById('Filter');
    const filter = filterEl ? (filterEl.value ?? "") : "";
    await refreshOffersList(customerId, filter);
});

// Start – policz od razu po załadowaniu partiala (opcjonalnie)
scheduleRecalc();
</script>
}