@model Trim.Models.ViewModels.EditUserVm;

<h2>Uaktualnij usera</h2>

<form id="userEditForm" method="post" asp-page-handler="SaveUser">
    @Html.AntiForgeryToken()
    <input type="hidden" name="userId" value="@Model.UserId" />

    <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

    <div class="mb-2">
        <label class="form-label" asp-for="FirstName"></label>
        <input class="form-control" asp-for="FirstName" />
        <span class="text-danger" asp-validation-for="FirstName"></span>
    </div>

    <div class="mb-2">
        <label class="form-label" asp-for="LastName"></label>
        <input class="form-control" asp-for="LastName" />
        <span class="text-danger" asp-validation-for="LastName"></span>
    </div>

    <div class="mb-2">
        <label class="form-label" asp-for="Email"></label>
        <input class="form-control" asp-for="Email" />
        <span class="text-danger" asp-validation-for="Email"></span>
    </div>

    <div class="mb-3">
        <label class="form-label" asp-for="SelectedRole">Rola</label>
        <select class="form-select" asp-for="SelectedRole" asp-items="Model.Roles">
            <option value="">-- wybierz rolę --</option>
        </select>
        <span class="text-danger" asp-validation-for="SelectedRole"></span>
    </div>

    <div class="d-flex gap-2">
        <button class="btn btn-primary js-save-user" type="button">Zapisz</button>
        <button class="btn btn-outline-secondary js-cancel-edit-user" type="button">Anuluj</button>
    </div>
</form>
