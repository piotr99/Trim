@page
@using Microsoft.AspNetCore.Mvc.Rendering
@model Trim.Pages.Admin.RegisterUserModel

@{
    ViewData["Title"] = "Rejestracja";
}

<h1>@ViewData["Title"]</h1>

@if (TempData["Success"] is string msg)
{
    <div class="alert alert-success">@msg</div>
}

<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="All" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="RegisterModel.FirstName"></label>
                <input asp-for="RegisterModel.FirstName" class="form-control" />
                <span asp-validation-for="RegisterModel.FirstName" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="RegisterModel.LastName"></label>
                <input asp-for="RegisterModel.LastName" class="form-control" />
                <span asp-validation-for="RegisterModel.LastName" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="RegisterModel.Email"></label>
                <input asp-for="RegisterModel.Email" class="form-control" />
                <span asp-validation-for="RegisterModel.Email" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="RegisterModel.Password"></label>
                <input asp-for="RegisterModel.Password" class="form-control" type="password" />
                <span asp-validation-for="RegisterModel.Password" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="RoleName" class="form-label">Wybierz rolę</label>
                <select asp-for="RoleName"
                        class="form-select"
                        asp-items="@(new SelectList(Model.AllRoles))">
                    <option value="">-- Wybierz rolę --</option>
                </select>
                <span asp-validation-for="RoleName" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">Zarejestruj</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
