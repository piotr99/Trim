{
  "ConnectionStrings": {
    "MainDb": "Server=localhost,1439;Database=TrimDB;User Id=sa;Password=TRIM@Passw0rd;Encrypt=False;"
  },
  "Ollama": {
    "BaseUrl": "http://localhost:11434",
    "Model": "gemma4:31b-cloud"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.MSSqlServer" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "MSSqlServer",
        "Args": {
          "connectionString": "MainDb",
          "sinkOptionsSection": {
            "tableName": "SystemLogs",
            "autoCreateSqlTable": true
          },
          "columnOptionsSection": {
            "customColumns": [
              {
                "ColumnName": "UserId",
                "DataType": "nvarchar",
                "DataLength": 50
              },
              {
                "ColumnName": "UserName",
                "DataType": "nvarchar",
                "DataLength": 100
              }
            ]
          }
        }
      }
    ]
  },
  "AllowedHosts": "*"
}